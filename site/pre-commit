#!/bin/bash
# Conformal pre-commit hook: analyzes staged .m files.
# Install: cp pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

CONFORMAL="conformal"  # adjust path if needed

staged=$(git diff --cached --name-only --diff-filter=ACM | grep '\.m$')
if [ -z "$staged" ]; then
    exit 0
fi

failed=0
for f in $staged; do
    output=$("$CONFORMAL" "$f" 2>&1)
    if echo "$output" | grep -q "^  - W_"; then
        echo "$output" | head -1
        echo "$output" | grep "^  - W_"
        echo ""
        failed=1
    fi
done

if [ $failed -ne 0 ]; then
    echo "Conformal found warnings in staged .m files."
    echo "Commit anyway with --no-verify, or fix the issues above."
    exit 1
fi
